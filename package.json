{
  "name": "duet-orchestrator",
  "version": "0.1.0",
  "private": true,
  "description": "Local Claude Code and Codex coding-agent orchestrator.",
  "type": "module",
  "bin": {
    "duet": "./dist/cli.js",
    "duetd": "./dist/duetd.js",
    "duet-mcp": "./dist/duet-mcp.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/cli.ts",
    "doctor": "tsx src/cli.ts doctor",
    "doctor:live": "tsx src/cli.ts doctor --live",
    "service": "tsx src/duetd.ts",
    "test": "tsx --test tests/**/*.test.ts",
    "test:dashboard": "tsx --test tests/browser/**/*.smoke.ts"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@openai/codex": "0.139.0",
    "cross-spawn": "^7.0.6",
    "smol-toml": "^1.6.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.49.1",
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0"
  }
}
