{
  "name": "duet-orchestrator",
  "version": "0.1.0",
  "private": true,
  "description": "Local Claude Code and Codex coding-agent orchestrator.",
  "type": "module",
  "bin": {
    "duet": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "tsx src/cli.ts",
    "doctor": "tsx src/cli.ts doctor",
    "doctor:live": "tsx src/cli.ts doctor --live",
    "test": "tsx --test tests/**/*.test.ts"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@openai/codex": "0.139.0",
    "cross-spawn": "^7.0.6",
    "smol-toml": "^1.6.1"
  },
  "devDependencies": {
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.9.0"
  }
}
